# MoziRadar configuration
# Copy this to .env and fill in your values

# Port the app listens on (default: 3421)
PORT=3421

# Host binding: 0.0.0.0 for LAN access, 127.0.0.1 for localhost only
HOST=0.0.0.0

# TMDB API key (free at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# AI provider for recommendations: claude | openai | deepseek | gemini
AI_PROVIDER=claude

# API key for the chosen AI provider
AI_API_KEY=

# Optional: custom OpenAI-compatible base URL (for DeepSeek, local Ollama, etc.)
# AI_BASE_URL=https://api.deepseek.com/v1

# Path to the SQLite database file
DB_PATH=./store/moziradar.db
